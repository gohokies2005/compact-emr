+/**
+ * Shared database-facing structural types used by route modules.
+ *
+ * This file intentionally uses literal unions and structural delegate types rather
+ * than importing generated Prisma types. The project keeps backend builds working
+ * before a generated Prisma client is present.
+ */
+
+export type Role = 'admin' | 'ops_staff' | 'physician' | 'veteran';
+
+export type ClaimType = 'initial' | 'supplemental' | 'hlr' | 'appeal_bva';
+
+export type CaseStatus =
+  | 'intake'
+  | 'records'
+  | 'viability'
+  | 'drafting'
+  | 'physician_review'
+  | 'correction_requested'
+  | 'correction_review'
+  | 'delivered'
+  | 'paid'
+  | 'rejected';
+
+export interface AppUserRecord {
+  id: string;
+  cognitoSub: string;
+  email: string;
+  role: Role;
+}
+
+export interface VeteranLiteRecord {
+  id: string;
+  firstName?: string | null;
+  lastName?: string | null;
+  email?: string | null;
+}
+
+export interface PhysicianLiteRecord {
+  id: string;
+  displayName?: string | null;
+  name?: string | null;
+  email?: string | null;
+}
+
+export interface CaseRecord {
+  id: string;
+  veteranId: string;
+  claimedCondition: string;
+  claimType: ClaimType;
+  status: CaseStatus;
+  version: number;
+  currentVersion?: number | null;
+  framingChoice?: string | null;
+  upstreamScCondition?: string | null;
+  veteranStatement?: string | null;
+  inServiceEvent?: string | null;
+  assignedPhysicianId?: string | null;
+  refundEligible?: boolean | null;
+  createdAt?: Date | string;
+  updatedAt?: Date | string;
+  veteran?: VeteranLiteRecord;
+  assignedPhysician?: PhysicianLiteRecord | null;
+  _count?: Record<string, number>;
+  documents?: readonly unknown[];
+  draftJobs?: readonly unknown[];
+  corrections?: readonly unknown[];
+  emails?: readonly unknown[];
+  payments?: readonly unknown[];
+}
+
+export interface ActivityLogCreateInput {
+  actorUserId: string;
+  action: string;
+  caseId?: string | null;
+  veteranId?: string | null;
+  detailsJson?: Record<string, unknown>;
+}
+
+export interface ActivityLogDelegate {
+  create(args: { data: ActivityLogCreateInput }): Promise<unknown>;
+}
+
+export interface CaseDelegate {
+  findMany(args?: Record<string, unknown>): Promise<CaseRecord[]>;
+  findFirst(args?: Record<string, unknown>): Promise<CaseRecord | null>;
+  findUnique(args?: Record<string, unknown>): Promise<CaseRecord | null>;
+  count(args?: Record<string, unknown>): Promise<number>;
+  create(args: Record<string, unknown>): Promise<CaseRecord>;
+  update(args: Record<string, unknown>): Promise<CaseRecord>;
+}
+
+export interface VeteranDelegate {
+  findUnique(args?: Record<string, unknown>): Promise<VeteranLiteRecord | null>;
+  findFirst?(args?: Record<string, unknown>): Promise<VeteranLiteRecord | null>;
+}
+
+export interface DraftJobDelegate {
+  findMany(args?: Record<string, unknown>): Promise<unknown[]>;
+}
+
+export interface CorrectionDelegate {
+  findMany(args?: Record<string, unknown>): Promise<unknown[]>;
+}
+
+export interface AppDbTransaction {
+  case: CaseDelegate;
+  veteran: VeteranDelegate;
+  draftJob: DraftJobDelegate;
+  correction: CorrectionDelegate;
+  activityLog: ActivityLogDelegate;
+}
+
+export interface AppDb extends AppDbTransaction {
+  $transaction<T>(fn: (tx: AppDbTransaction) => Promise<T>): Promise<T>;
+}
