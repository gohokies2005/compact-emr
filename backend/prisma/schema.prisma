generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum YesNoUnknown {
  yes
  no
  unknown

  @@map("yes_no_unknown")
}

enum ClaimType {
  initial
  supplemental
  hlr
  appeal_bva

  @@map("claim_type")
}

enum CaseStatus {
  intake
  records
  viability
  drafting
  rn_review
  physician_review
  correction_requested
  correction_review
  delivered
  paid
  rejected
  needs_rn_decision // Gate-2 dx/event verification halt — RN must decide (override/switch/proceed)
  needs_records // Gate-2 halt where the RN chose to pause and gather more records

  @@map("case_status")
}

enum CdsVerdict {
  accept
  caution
  reject
  not_yet_run

  @@map("cds_verdict")
}

enum DraftJobState {
  queued
  running
  done
  failed
  halted // Gate-2 pre-draft verification halt — terminal-for-the-watcher; resumed via a NEW job

  @@map("draft_job_state")
}

enum CorrectionReason {
  veteran_added_info
  physician_caught_error
  ops_caught_error
  va_examiner_feedback
  other

  @@map("correction_reason")
}

enum BillingTier {
  free_first
  free_our_fault
  paid_50

  @@map("billing_tier")
}

enum PhysicianActivity {
  letter_review
  correction_review

  @@map("physician_activity")
}

enum EmailDirection {
  inbound
  outbound

  @@map("email_direction")
}

enum PaymentKind {
  review_50
  letter_350
  letter_500
  refund
  correction_fee

  @@map("payment_kind")
}

enum AppRole {
  physician
  ops_staff
  admin

  @@map("app_role")
}

model AppUser {
  id          String   @id @default(uuid())
  cognitoSub  String   @unique @map("cognito_sub")
  email       String   @unique
  name        String?  @db.VarChar(120)
  active      Boolean  @default(true)
  roles       AppUserRole[]
  assignedCases Case[]  @relation("CaseAssignedRn")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  version     Int      @default(1)

  @@index([email])
  @@index([active])
  @@map("app_users")
}

model CognitoGroup {
  name      AppRole @id
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("cognito_groups")
}

model AppUserRole {
  userId String  @map("user_id")
  role   AppRole
  user   AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@index([role])
  @@map("app_user_roles")
}

model Veteran {
  id               String       @id
  lastName         String       @map("last_name")
  firstName        String       @map("first_name")
  dob              DateTime     @db.Date
  email            String
  phone            String?
  address          String?
  branch           String?
  serviceStartYear Int?         @map("service_start_year")
  serviceEndYear   Int?         @map("service_end_year")
  combatVeteran    YesNoUnknown? @map("combat_veteran")
  pactArea         YesNoUnknown? @map("pact_area")
  teraConceded     YesNoUnknown? @map("tera_conceded")
  heightIn         Int?         @map("height_in")
  weightLb         Int?         @map("weight_lb")
  // RN affirmation that this veteran has NO service-connected conditions. Disambiguates an
  // empty SC chart (not entered yet) from confirmed-none, so the draft-readiness gate can tell a
  // secondary claim "no SC primary to attach to" instead of "go enter the rating decision".
  noScConditionsConfirmed Boolean @default(false) @map("no_sc_conditions_confirmed")
  inactive         Boolean      @default(false)
  searchVector     Unsupported("tsvector")? @map("search_vector")
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  version          Int          @default(1)

  scConditions      ScCondition[]
  activeProblems    ActiveProblem[]
  activeMedications ActiveMedication[]
  cases             Case[]
  activityLogs      ActivityLog[]
  chartNotes        ChartNote[]
  emails            Email[] // Feature B: veteran-level email log (chart tab)

  @@index([lastName, firstName])
  @@index([email])
  @@index([branch])
  @@index([inactive])
  @@map("veterans")
}

// VA claim status of a charted condition: service_connected (granted/established — the default
// and the historical meaning of this table), pending (claim filed, awaiting decision), or denied.
// Lets the chart capture the veteran's full claim history, not just already-granted conditions.
enum ScConditionStatus {
  service_connected
  pending
  denied

  @@map("sc_condition_status")
}

model ScCondition {
  id          String   @id @default(uuid())
  veteranId   String   @map("veteran_id")
  condition   String
  dcCode      String?  @map("dc_code")
  ratingPct   Int?     @map("rating_pct")
  status      ScConditionStatus @default(service_connected)
  grantedDate DateTime? @map("granted_date") @db.Date
  // Provenance (chart auto-extract). source='manual' is the default, so every existing row and
  // every row the manual POST path creates stays manual and is IMMUTABLE to the extractor.
  source           String    @default("manual")
  sourceDocumentId String?   @map("source_document_id")
  sourcePage       Int?      @map("source_page")
  sourceQuote      String?   @map("source_quote")
  confidence       Float?
  needsReview      Boolean   @default(false) @map("needs_review")
  extractedAt      DateTime? @map("extracted_at") @db.Timestamptz(6)
  extractionRunId  String?   @map("extraction_run_id")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  version     Int      @default(1)
  veteran     Veteran  @relation(fields: [veteranId], references: [id], onDelete: Cascade)

  @@index([veteranId])
  @@index([condition])
  @@index([dcCode])
  @@map("sc_conditions")
}

model ActiveProblem {
  id        String   @id @default(uuid())
  veteranId String   @map("veteran_id")
  problem   String
  icd10     String?  @db.VarChar(16)
  notes     String?
  // Provenance (chart auto-extract) — see ScCondition. source defaults to 'manual'.
  source           String    @default("manual")
  sourceDocumentId String?   @map("source_document_id")
  sourcePage       Int?      @map("source_page")
  sourceQuote      String?   @map("source_quote")
  confidence       Float?
  needsReview      Boolean   @default(false) @map("needs_review")
  extractedAt      DateTime? @map("extracted_at") @db.Timestamptz(6)
  extractionRunId  String?   @map("extraction_run_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  version   Int      @default(1)
  veteran   Veteran  @relation(fields: [veteranId], references: [id], onDelete: Cascade)

  @@index([veteranId])
  @@index([problem])
  @@index([icd10])
  @@map("active_problems")
}

model ActiveMedication {
  id         String   @id @default(uuid())
  veteranId  String   @map("veteran_id")
  drugName   String   @map("drug_name")
  dose       String?
  frequency  String?
  indication String?
  // Provenance (chart auto-extract) — see ScCondition. source defaults to 'manual'.
  source           String    @default("manual")
  sourceDocumentId String?   @map("source_document_id")
  sourcePage       Int?      @map("source_page")
  sourceQuote      String?   @map("source_quote")
  confidence       Float?
  needsReview      Boolean   @default(false) @map("needs_review")
  extractedAt      DateTime? @map("extracted_at") @db.Timestamptz(6)
  extractionRunId  String?   @map("extraction_run_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  version    Int      @default(1)
  veteran    Veteran  @relation(fields: [veteranId], references: [id], onDelete: Cascade)

  @@index([veteranId])
  @@index([drugName])
  @@index([indication])
  @@map("active_medications")
}

// Chart auto-extract run ledger. The @@unique([caseId, triggerHash]) is the fire-exactly-once
// latch: a concurrent doc-completion that also sees "all docs OCR'd" hits the unique violation
// and skips the duplicate enqueue. triggerHash = hash of the case's (documentId, terminalStatus)
// set, so a NEW upload finishing OCR yields a new hash -> a fresh run (merge), while a duplicate
// completion callback for the same doc set is a no-op. Also the Phase A audit sink.
model ChartExtractionRun {
  id           String    @id @default(uuid())
  caseId       String    @map("case_id")
  veteranId    String    @map("veteran_id")
  triggerHash  String    @map("trigger_hash") @db.VarChar(64)
  status       String    @default("queued") // queued | running | complete | failed
  itemsWritten Int       @default(0) @map("items_written")
  itemsSkipped Int       @default(0) @map("items_skipped")
  resultJson   Json?     @map("result_json") // Phase A: the full grounded extraction for eyeball review
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt  DateTime? @map("completed_at") @db.Timestamptz(6)

  @@unique([caseId, triggerHash], map: "chart_extraction_run_case_hash_uq")
  @@index([caseId])
  @@map("chart_extraction_runs")
}

model Case {
  id                  String     @id
  veteranId           String     @map("veteran_id")
  claimedCondition    String     @map("claimed_condition")
  // Multi-condition clustered claims: the full set of same-body-system conditions argued in
  // ONE letter. claimedCondition stays the primary (RN's first pick / display / drafter primary);
  // claimedConditions is the complete set CDS scores (verdict follows the best-odds member).
  claimedConditions   String[]   @default([]) @map("claimed_conditions")
  claimType           ClaimType  @map("claim_type")
  // Prior-denial signals for the delivery cover-memo predicate (coverMemoRequirement mirror).
  // A claimType of supplemental/hlr/appeal_bva ALONE implies a prior denial, but the local FRN
  // HARD RULE (feedback_supplemental_appeals_need_cover_letter) is that a denial signal — not the
  // intake dropdown alone — promotes a case to "needs a cover memo." These two additive fields
  // carry that signal explicitly so an `initial` case that is really an appeal still generates the
  // memo. Both optional/defaulted → existing rows unaffected.
  previouslyDenied    Boolean    @default(false) @map("previously_denied")
  priorDenialReason   String?    @map("prior_denial_reason")
  priorDecisionDate   DateTime?  @map("prior_decision_date") @db.Date
  framingChoice       String?    @map("framing_choice")
  upstreamScCondition String?    @map("upstream_sc_condition")
  veteranStatement    String?    @map("veteran_statement")
  inServiceEvent      String?    @map("in_service_event")
  status              CaseStatus @default(intake)
  cdsVerdict          CdsVerdict @default(not_yet_run) @map("cds_verdict")
  cdsOddsPct          Int?       @map("cds_odds_pct")
  cdsRationale        Json?      @map("cds_rationale")
  assignedPhysicianId String?    @map("assigned_physician_id")
  assignedRnId        String?    @map("assigned_rn_id")
  refundEligible      Boolean    @default(false) @map("refund_eligible")
  currentVersion      Int        @default(0) @map("current_version")
  // Drafter integration: terminal-state snapshot mirrored from v<N>_qa_grade.json + final
  // pipeline_manifest.json. Triage filter for physician inbox is
  // (runComplete=true AND shipRecommendation='ship') — anything else stays in the ops queue.
  probativeScore      Int?       @map("probative_score")
  grade               String?    @db.VarChar(8)
  shipRecommendation  String?    @map("ship_recommendation") @db.VarChar(8)
  operatorState       String?    @map("operator_state") @db.VarChar(24)
  runComplete         Boolean?   @map("run_complete")
  // G8: RN-facing message accompanying operatorState. The spine's summarizeForOperator()
  // emits {state, message}; we store the message verbatim so the RN/physician UI can render
  // it without making the UI rebuild the message from state. Also populated by the
  // stuck-job watcher when it sweeps stale jobs (so RN sees "We had a problem and gave up
  // after 10 minutes — click Retry" instead of "system error").
  operatorMessage     String?    @map("operator_message")
  // Quick-note: a lightweight at-a-glance scratch note on the claim row (Epic/Cerner-style), for
  // fast references like "rejected, refund offered" / "waiting on records". OVERWRITE scratchpad
  // (not an append-list — substantive history lives in chart Notes). Multi-user (RN + physician);
  // last-writer-wins with an author+time stamp. Set ONLY by PUT /cases/:id/quick-note, which never
  // touches `version` (it must not collide with the optimistic-concurrency used by editor/assignment).
  quickNote           String?    @map("quick_note")
  quickNoteBy         String?    @map("quick_note_by")   // app user id of the last editor
  quickNoteAt         DateTime?  @map("quick_note_at") @db.Timestamptz(6)
  createdAt           DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  archivedAt          DateTime?  @map("archived_at") @db.Timestamptz(6) // soft-delete: hidden from default views, restorable
  version             Int        @default(1)

  veteran           Veteran     @relation(fields: [veteranId], references: [id], onDelete: Cascade)
  assignedPhysician Physician?  @relation(fields: [assignedPhysicianId], references: [id])
  assignedRn        AppUser?    @relation("CaseAssignedRn", fields: [assignedRnId], references: [id], onDelete: SetNull)
  documents         Document[]
  draftJobs         DraftJob[]
  corrections       Correction[]
  compensationRows  PhysicianCompensation[]
  emails            Email[]
  activityLogs      ActivityLog[]
  payments          Payment[]
  letterRevisions   LetterRevision[]
  deliveryTokens    DeliveryToken[]
  caseMessages      CaseMessage[]
  draftDecisions    DraftDecision[]

  @@index([veteranId])
  @@index([assignedPhysicianId])
  @@index([assignedRnId])
  @@index([claimedCondition])
  @@index([status, updatedAt])
  @@index([veteranId, status])
  @@index([assignedPhysicianId, runComplete, shipRecommendation], map: "cases_physician_inbox_idx")
  @@index([archivedAt])
  @@map("cases")
}

// Gate-1 (RN checklist) + Gate-2 (AI dx/event verification) decision log. Every override reason is
// shown IN THE CHART (case-page "Decisions & overrides" panel), per the owner's hard requirement —
// never log-only. One row per decision/attestation.
model DraftDecision {
  id           String   @id @default(uuid())
  caseId       String   @map("case_id")
  draftAttempt Int      @map("draft_attempt") // distinguishes re-runs
  gate         Int      @db.SmallInt // 1 = checklist, 2 = ai_verification
  item         String   @db.VarChar(40) // dx_present | in_service_event | sc_conditions | prior_denial | nexus_switch
  decision     String   @db.VarChar(20) // yes | no | not_applicable | override | switch_accept | switch_decline | proceed | pause
  reason       String? // required for override / decline / switch_decline; else null
  rnUser       String   @map("rn_user")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  case         Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, draftAttempt])
  @@map("draft_decisions")
}

// Advisory "Ask AI about this case" oversight + cost log — one row per question (spec §1.7). No FK to
// Case (the audit log must survive case deletion). coverage_gap feeds the library-build roadmap
// (AI-window red-team finding). status='refused' covers the empty-question/over-budget/not-found paths.
model AdvisoryQuery {
  id            String   @id @default(uuid())
  caseId        String?  @map("case_id")
  veteranId     String?  @map("veteran_id")
  userId        String   @map("user_id")
  userRole      String   @map("user_role") @db.VarChar(20)
  view          String   @db.VarChar(24) // which surface asked: rn_chart | physician_chart | ...
  question      String
  status        String   @db.VarChar(20) // retrieval status: ok | thin | empty | degraded | refused
  modeRan       String[] @default([]) @map("mode_ran")
  citationsJson Json?    @map("citations_json")
  coverageGap   Json?    @map("coverage_gap")
  costUsd       Decimal? @map("cost_usd") @db.Decimal(10, 5)
  answerChars   Int?     @map("answer_chars")
  answer        String? // the answer text, persisted so the Q&A thread renders when the case is reopened
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([caseId])
  @@index([createdAt])
  @@map("advisory_queries")
}

enum LetterRevisionSource {
  drafter_run     // mirror of a completed DraftJob (optional; unified-timeline mode)
  editor_save     // RN/physician full-text WYSIWYG save
  surgical_ai     // physician surgical-AI limited-scope edit (Phase 2)
  approved_final  // physician approve -> final render (no DRAFT watermark)

  @@map("letter_revision_source")
}

// In-EMR letter-editor revision timeline. Every content change is a NEW row + a new
// immutable S3 v<N> key — the cloud equivalent of the FRN "version advances on any
// content change; never overwrite in place" HARD RULE. Deliberately separate from
// DraftJob (pipeline runs, with grade/cost/heartbeat/state semantics + a stuck-job
// watcher that would sweep a fake row) and from Correction (billable VA-feedback
// corrections) — an editor save is neither. Source of truth for "latest letter" is
// max(version) across DraftJob + LetterRevision until/unless drafter completions are
// mirrored in (the optional unified-timeline mode).
model LetterRevision {
  id                String               @id @default(uuid())
  caseId            String               @map("case_id")
  version           Int                  // = parentVersion + 1
  parentVersion     Int                  @map("parent_version")
  source            LetterRevisionSource
  artifactTxtS3Key  String               @map("artifact_txt_s3_key")  @db.VarChar(500)
  artifactPdfS3Key  String?              @map("artifact_pdf_s3_key")  @db.VarChar(500)
  artifactDocxS3Key String?              @map("artifact_docx_s3_key") @db.VarChar(500)
  editedBy          String               @map("edited_by")   // cognito sub of the editor
  editorRole        String               @map("editor_role") // cognito group: physician|ops_staff|admin
  sanityJson        Json?                @map("sanity_json")  // warn-only sanity findings snapshot
  createdAt         DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  case              Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Optimistic-concurrency backstop: two saves against the same base_version both compute
  // the same new version; the second INSERT hits this unique constraint -> 409 (same
  // proven pattern as draft_jobs_case_id_in_flight_uq).
  @@unique([caseId, version], map: "letter_revisions_case_version_uq")
  @@index([caseId])
  @@index([caseId, version])
  @@map("letter_revisions")
}

// Per-case RN<->physician message thread, distinct from veteran-scoped ChartNotes. Read-state is
// single readAt/readBySub per message (strictly a 2-party thread + admin observer): a message is
// "unread for me" until the counterparty (senderSub != me) marks it read. PHI is expected in the
// body (clinical back-and-forth) — validated for length only, never PHI-stripped.
model CaseMessage {
  id          String    @id @default(uuid())
  caseId      String    @map("case_id")
  senderSub   String    @map("sender_sub")
  senderRole  String    @map("sender_role") @db.VarChar(16)
  body        String
  readAt      DateTime? @map("read_at") @db.Timestamptz(6)
  readBySub   String?   @map("read_by_sub")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  case        Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([caseId, createdAt])
  @@index([caseId, readAt])
  @@map("case_messages")
}

model Document {
  id          String   @id @default(uuid())
  caseId      String   @map("case_id")
  filename    String
  sizeBytes   BigInt   @map("size_bytes")
  contentType String   @map("content_type")
  docTag      String?  @map("doc_tag")
  pageCount   Int?     @map("page_count")
  s3Key       String   @unique @map("s3_key")
  uploadedAt  DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  uploadedBy  String   @map("uploaded_by")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  version     Int      @default(1)
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  pages       DocumentPage[]

  @@index([caseId])
  @@index([caseId, docTag])
  @@index([filename])
  @@index([uploadedBy])
  @@map("documents")
}

model DraftJob {
  id          String        @id @default(uuid())
  caseId      String        @map("case_id")
  version     Int
  sqsMessageId String?      @map("sqs_message_id")
  state       DraftJobState @default(queued)
  enqueuedAt  DateTime      @default(now()) @map("enqueued_at") @db.Timestamptz(6)
  startedAt   DateTime?     @map("started_at") @db.Timestamptz(6)
  completedAt DateTime?     @map("completed_at") @db.Timestamptz(6)
  errorMessage String?      @map("error_message")
  // Drafter integration: the wrapper running the FRN Node drafter posts progress here
  // (manifestSnapshot updates every phase transition) and final on terminal
  // (gradeSidecarJson + artifact*S3Key). Fields mirror pipeline_manifest.json +
  // v<N>_qa_grade.json shapes exactly — no impedance at the wire.
  manifestSnapshot  Json?      @map("manifest_snapshot")
  currentPhase      String?    @map("current_phase") @db.VarChar(40)
  nextRetryInS      Int?       @map("next_retry_in_s")
  failureClass      String?    @map("failure_class") @db.VarChar(20)
  gradeSidecarJson  Json?      @map("grade_sidecar_json")
  haltPayloadJson   Json?      @map("halt_payload_json") // Gate-2 halt: plain-English reason + switchProposal + evidence the RN UI renders
  artifactPdfS3Key  String?    @map("artifact_pdf_s3_key") @db.VarChar(500)
  artifactTxtS3Key  String?    @map("artifact_txt_s3_key") @db.VarChar(500)
  artifactDocxS3Key String?    @map("artifact_docx_s3_key") @db.VarChar(500)
  strategyOverride  String?    @map("strategy_override")
  parentVersion     Int?       @map("parent_version")
  workerId          String?    @map("worker_id") @db.VarChar(80)
  lastHeartbeatAt   DateTime?  @map("last_heartbeat_at") @db.Timestamptz(6)
  // Architect QA F1: drafter-export materialization bundle lives in S3 so HttpApi/Lambda
  // payload limits don't bite on big charts. POST /draft writes the bundle once and the
  // wrapper reads from S3 using its Fargate task role's phiBucket read grant.
  bundleS3Key       String?    @map("bundle_s3_key") @db.VarChar(500)
  // Per-claim drafting cost: the Fargate drafter worker posts the US-dollar LLM spend for the
  // run (e.g. 3.42; 0 when no metered Anthropic spend) on POST /complete. Summed per case for
  // the admin-only cost report. Nullable — older rows (pre-2026-06-02) have no cost recorded.
  costUsd           Decimal?   @db.Decimal(10, 4) @map("cost_usd")
  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  case        Case          @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@index([state])
  @@index([caseId, version])
  @@index([lastHeartbeatAt])
  @@map("draft_jobs")
}

model Correction {
  id               String           @id @default(uuid())
  caseId            String           @map("case_id")
  fromVersion       Int              @map("from_version")
  toVersion         Int?             @map("to_version")
  correctionReason  CorrectionReason @map("correction_reason")
  correctionNote    String           @map("correction_note")
  affectsSections   Json             @map("affects_sections")
  billingTier       BillingTier      @map("billing_tier")
  requestedBy       String           @map("requested_by")
  requestedAt       DateTime         @default(now()) @map("requested_at") @db.Timestamptz(6)
  approvedBy        String?          @map("approved_by")
  approvedAt        DateTime?        @map("approved_at") @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
