{
  "name": "infra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "compact-emr": "bin/compact-emr.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint . --max-warnings=0",
