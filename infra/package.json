    "@aws-sdk/client-cognito-identity-provider": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "aws-cdk": "latest",
    "eslint": "latest",
    "@eslint/js": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "ts-node": "latest",
    "vitest": "latest",
    "esbuild": "latest",
    "tsx": "latest"
  }
}
