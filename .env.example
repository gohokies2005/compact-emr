# Local development only. Do not commit .env files.
NODE_ENV=development
AWS_REGION=us-east-1
APP_DOMAIN=emr.flatratenexus.com
API_DOMAIN=api.emr.flatratenexus.com

# Local Postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=compact_emr
POSTGRES_USER=compact_emr
POSTGRES_PASSWORD=compact_emr_dev_password
DATABASE_URL=postgresql://compact_emr:compact_emr_dev_password@localhost:5432/compact_emr

# LocalStack
LOCALSTACK_ENDPOINT=http://localhost:4566
LOCAL_S3_BUCKET=compact-emr-local-phi

# Cognito local stub
COGNITO_LOCAL_URL=http://localhost:9229
COGNITO_USER_POOL_ID=local_compact_emr_pool
COGNITO_CLIENT_ID=local_compact_emr_client
JWT_ISSUER=http://localhost:9229/local_compact_emr_pool

# Phase 1 auth test/local verifier
AUTH_TEST_JWT_SECRET=phase1-local-secret
AUTH_TEST_ISSUER=compact-emr-local
AUTH_TEST_AUDIENCE=compact-emr-api
BOOTSTRAP_ADMIN_SUB=local-admin-sub
BOOTSTRAP_ADMIN_EMAIL=admin@flatratenexus.local
