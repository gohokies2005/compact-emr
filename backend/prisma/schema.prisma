model Email {
  id             String         @id @default(uuid())
  // Feature B (Ryan 2026-06-06): caseId is NULLABLE. An inbound email matched to a veteran but not a
  // specific claim is chart-level (caseId NULL); an UNMATCHED email (no veteran resolved) has BOTH
  // NULL and sits in the unmatched queue for an RN to assign. Outbound delivery rows keep caseId.
  caseId         String?        @map("case_id")
  veteranId      String?        @map("veteran_id")
  direction      EmailDirection
  subject        String
  body           String
  fromAddress    String         @map("from_address")
  toAddress      String         @map("to_address")
  // The FRN staff mailbox this landed in / went out from (info@, admin@, a staff address) — the
  // "who on our side" of the audit log. NULL for legacy/outbound rows that predate the field.
  mailbox        String?
  // RFC 5322 Message-ID — the idempotent-ingest dedupe key. GLOBAL @unique: exactly ONE row per
  // message, first monitored mailbox to ingest wins (a message CC'd to two monitored mailboxes
  // dedupes to one row; the ingest route logs the dropped mailbox). Multiple NULLs are allowed
  // (Postgres btree unique ignores NULLs) so outbound stub rows with no Message-ID coexist. Do NOT
  // "fix" this to NOT NULL / a partial index without re-checking delivery.ts inserts.
  messageId      String?        @unique @map("message_id")
  snippet        String?        // first ~140 chars for the collapsed log row
  rawS3Key       String?        @map("raw_s3_key")        // raw RFC822 in phiBucket emails/<id>/
  attachmentsJson Json?         @map("attachments_json")  // [{filename,s3Key,contentType,sizeBytes}]
  receivedAt     DateTime?      @map("received_at") @db.Timestamptz(6) // inbound time (outbound uses sentAt)
  // sentAt is set ONLY when a real transmit happens. A composed/queued (stub) email leaves this
  // NULL — a non-null sentAt is the source of truth for "actually sent". Widened from NOT NULL to
  // nullable (additive: existing rows keep their value).
  sentAt         DateTime?      @map("sent_at") @db.Timestamptz(6)
  // Lifecycle of an outbound email. 'sent' for historically-transmitted rows (back-compat default),
  // 'queued' for a composed-but-not-yet-transmitted (stub) delivery email. Additive, defaulted.
  status         String         @default("sent")
  gmailMessageId String?        @map("gmail_message_id")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  version        Int            @default(1)
  case           Case?          @relation(fields: [caseId], references: [id], onDelete: Cascade)
  veteran        Veteran?       @relation(fields: [veteranId], references: [id], onDelete: SetNull)

  @@index([caseId])
  // Compound indexes match the actual queries: chart tab = a veteran's emails newest-first; claim
  // tab = a case's emails newest-first. Sort key is the effective timestamp (receivedAt for inbound).
  @@index([caseId, receivedAt],    map: "emails_case_received_idx")
  @@index([veteranId, receivedAt], map: "emails_veteran_received_idx")
  @@index([sentAt])
  @@index([fromAddress])
  @@index([toAddress])
  @@index([status])
  @@index([gmailMessageId])
  @@map("emails")
}

// Feature B — the set of Google Workspace mailboxes the gmail-ingest poller monitors (Ryan 2026-06-06:
// "add an email profile to the EMR ... easily add emails as I add staff"). Managed in-app from an admin
// page (no AWS console); the ingester reads the ACTIVE addresses via GET /internal/monitored-mailboxes.
// `active=false` keeps a mailbox's history but stops polling it (e.g. a departed staffer).
model MonitoredMailbox {
  id        String   @id @default(uuid())
  address   String   @unique          // normalized lowercase email
  label     String?                    // friendly note, e.g. "Primary intake" / "Jane (RN)"
  active    Boolean  @default(true)
  addedBy   String?  @map("added_by")  // editor email
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("monitored_mailboxes")
}

// Feature: password-protected PDF delivery portal (Ryan 2026-06-06). On a confirmed Stripe payment the
// EMR mints a token (the URL secret) + a unique password (emailed via SES). The veteran visits
// /d/<token>, enters the password, and the public portal returns a short-lived presigned S3 URL to the
// signed letter PDF — no PHI attachment in email. passwordHash = sha256 hex (never the plaintext).
model DeliveryToken {
  id             String    @id @default(uuid())
  caseId         String    @map("case_id")
  token          String    @unique          // long random URL secret
  passwordHash   String    @map("password_hash")
  letterVersion  Int       @map("letter_version")
  pdfS3Key       String    @map("pdf_s3_key") // drafter-artifacts/<caseId>/v<N>/*.pdf (validated)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  downloadCount  Int       @default(0) @map("download_count")
  lastAccessedAt DateTime? @map("last_accessed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  case           Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("delivery_tokens")
}

